{
    "name": "helsingborg-stad/project-synchronizer",
    "description": "A utitlity to synchronize projects from one repo to another",
    "type": "library",
    "license": "MIT",
    "scripts": {
        "test": "phpunit --no-coverage --testdox",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --testdox",
        "lint": "vendor/bin/phpcs",
        "lint:changed": "vendor/bin/phpcs-changed origin/main",
        "fix": "vendor/bin/phpcbf",
        "fix:changed": "vendor/bin/phpcbf-changed origin/main",
        "sync:project": "php vendor/helsingborg-stad/project-synchronizer/ps.php"
    },
    "authors": [
        {
            "name": "Petter Andersson",
            "email": "petter.andersson@helsingborg.se"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "source/php/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "composer/semver": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "version": "0.1.14"
}